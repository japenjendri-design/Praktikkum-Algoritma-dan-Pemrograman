   "source": [
    "import math\n",
    "\n",
    "P = 200_000_000\n",
    "A = 400_000_000\n",
    "r = 0.10\n",
    "\n",
    "t = math.log(A / P) / math.log(1 + r)\n",
    "\n",
    "print(\"Waktu yang dibutuhkan:\", t, \"tahun\")\n",
    "print(\"Dibulatkan\", math.ceil(t), \"tahun\")"
   ]
